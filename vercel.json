{
  "version": 2,
  "builds": [
    {
      "src": "comprahorro-panama/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/comprahorro-panama/(.*)",
      "dest": "/comprahorro-panama/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/comprahorro-panama/index.html"
    }
  ],
  "rewrites": [
    { 
      "source": "/(.*)", 
      "destination": "/comprahorro-panama/index.html" 
    }
  ],
  "env": {
    "VITE_API_URL": "https://compr-ahorro-final.vercel.app"
  }
}
